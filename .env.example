# Database (optional — if not set, uses embedded PGlite)
# DATABASE_URL=postgresql://user:password@localhost:5432/onecli

# Auth — single-user mode by default (no login required).
# To enable Google OAuth login (multi-user), set all three:
# NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Plugin: Google (for connecting Google services — works in both auth modes)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Plugin: GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Plugin: Resend
# No server-side secrets needed — users provide their own API keys

# OAuth state signing (generate with: openssl rand -hex 32)
OAUTH_STATE_SECRET=
